# Airflow
AIRFLOW_UID=50000

# Email / SMTP (required for failure alerting)
# Copy to .env and fill with your credentials. See docs/EMAIL_SETUP.md for setup.
AIRFLOW__SMTP__SMTP_HOST=smtp.example.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your_email@example.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_app_password
AIRFLOW__SMTP__SMTP_MAIL_FROM=your_email@example.com
